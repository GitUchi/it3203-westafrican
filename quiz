  <!-- ================================================================
       QUIZ JAVASCRIPT
       All quiz logic lives here — no external libraries required.

       Key functions:
         gradeQuiz()  — reads inputs, scores each question, displays results
         resetQuiz()  — clears all inputs and hides result elements
         scoreQ5()    — helper for the multi-select (checkbox) question

       Answer key:
         Q1 (fill-in-the-blank): "wolof"         (case-insensitive)
         Q2 (radio):             "B"
         Q3 (radio):             "C"
         Q4 (radio):             "A"
         Q5 (checkboxes):        ["A", "C", "D"]  (all three must be checked)
  ================================================================ -->
  <script>

    /* ── Answer Key ────────────────────────────────────────────── */

    const ANSWER_KEY = {
      q1: "wolof",          // fill-in-the-blank, compared lowercase + trimmed
      q2: "B",
      q3: "C",
      q4: "A",
      q5: ["A", "C", "D"]  // multi-select: all three must be selected
    };

    /* Human-readable "correct answer" text shown in feedback */
    const CORRECT_ANSWER_TEXT = {
      q1: 'Wolof (the Wolof people of Senegal and Gambia)',
      q2: 'B — It is swallowed whole; chewing is considered improper.',
      q3: 'C — Ki ngombo, a Bantu word for okra.',
      q4: 'A — Beta-carotene (Vitamin A) present in the oil palm fruit.',
      q5: 'A, C, and D — Okra/gumbo tradition, black-eyed peas, and deep-frying techniques.'
    };

    /* ── gradeQuiz() ────────────────────────────────────────────
       Called when the user clicks "Submit Quiz".
       1. Validates that all questions are answered.
       2. Checks each answer against ANSWER_KEY.
       3. Shows per-question feedback.
       4. Calculates total score, shows results banner.
       5. Locks the form so answers cannot be changed.
    ─────────────────────────────────────────────────────────── */
    function gradeQuiz() {

      /* ── Collect user answers ── */

      const q1Answer = document.getElementById("q1-input").value.trim().toLowerCase();
      const q2Answer = getRadioValue("q2");
      const q3Answer = getRadioValue("q3");
      const q4Answer = getRadioValue("q4");
      const q5Answers = getCheckboxValues("q5"); // returns array of checked values

      /* ── Basic validation: make sure every question is answered ── */

      if (!q1Answer) {
        alert("Please answer Question 1 before submitting.");
        return;
      }
      if (!q2Answer) {
        alert("Please select an answer for Question 2 before submitting.");
        return;
      }
      if (!q3Answer) {
        alert("Please select an answer for Question 3 before submitting.");
        return;
      }
      if (!q4Answer) {
        alert("Please select an answer for Question 4 before submitting.");
        return;
      }
      if (q5Answers.length === 0) {
        alert("Please select at least one answer for Question 5 before submitting.");
        return;
      }

      /* ── Grade each question ── */

      // Q1: compare trimmed lowercase
      const q1Correct = (q1Answer === ANSWER_KEY.q1);

      // Q2–Q4: simple string comparison
      const q2Correct = (q2Answer === ANSWER_KEY.q2);
      const q3Correct = (q3Answer === ANSWER_KEY.q3);
      const q4Correct = (q4Answer === ANSWER_KEY.q4);

      // Q5: multi-select — user must have selected EXACTLY the correct set
      const q5Correct = scoreQ5(q5Answers, ANSWER_KEY.q5);

      /* ── Tally score (each question worth 1 point, max = 5) ── */

      const results = [q1Correct, q2Correct, q3Correct, q4Correct, q5Correct];
      const totalCorrect = results.filter(Boolean).length;
      const totalQuestions = results.length;
      const percentage = Math.round((totalCorrect / totalQuestions) * 100);
      const passed = percentage >= 60;

      /* ── Show per-question feedback ── */

      showFeedback("q1", q1Correct);
      showFeedback("q2", q2Correct);
      showFeedback("q3", q3Correct);
      showFeedback("q4", q4Correct);
      showFeedback("q5", q5Correct);

      /* ── Show results banner ── */

      const banner = document.getElementById("results-banner");
      const bannerResult = document.getElementById("banner-result-text");
      const bannerScore = document.getElementById("banner-score-text");

      banner.className = passed ? "pass" : "fail";
      bannerResult.textContent = passed ? "✓ Pass" : "✗ Not quite — keep studying!";
      bannerScore.textContent =
        "You scored " + totalCorrect + " out of " + totalQuestions +
        " (" + percentage + "%). " +
        (passed
          ? "Great work — you have a solid understanding of West African foods!"
          : "Review the site and try again. A score of 60% or higher is a Pass.");

      banner.style.display = "block";

      /* ── Lock the form so the user cannot change answers ── */

      document.getElementById("quiz-form").classList.add("quiz-locked");

      /* ── Swap button states: hide Submit, show Retake ── */

      document.getElementById("btn-submit").style.display = "none";
      document.getElementById("btn-reset").style.display = "inline-block";

      /* ── Scroll smoothly to the results banner ── */

      banner.scrollIntoView({ behavior: "smooth", block: "start" });
    }


    /* ── scoreQ5(userSelections, correctSelections) ─────────────
       Multi-select grading: the user's selection array must match
       the correct answer array exactly (same items, any order).
       Returns true only if the sets are identical.
    ─────────────────────────────────────────────────────────── */
    function scoreQ5(userArr, correctArr) {
      if (userArr.length !== correctArr.length) return false;
      const sortedUser = [...userArr].sort();
      const sortedCorrect = [...correctArr].sort();
      return sortedUser.every(function(val, idx) {
        return val === sortedCorrect[idx];
      });
    }


    /* ── showFeedback(questionId, isCorrect) ────────────────────
       Builds and displays the per-question feedback block.
       - Green styling + checkmark for correct answers
       - Red styling + X for incorrect answers, plus the correct answer
    ─────────────────────────────────────────────────────────── */
    function showFeedback(questionId, isCorrect) {
      const feedbackEl = document.getElementById(questionId + "-feedback");

      // Build the inner HTML for the feedback box
      if (isCorrect) {
        feedbackEl.innerHTML =
          '<div class="feedback-result-icon">✓ Correct!</div>';
        feedbackEl.className = "question-feedback correct";
      } else {
        feedbackEl.innerHTML =
          '<div class="feedback-result-icon">✗ Incorrect</div>' +
          '<div class="feedback-correct-answer">' +
            '<strong>Correct answer:</strong> ' + CORRECT_ANSWER_TEXT[questionId] +
          '</div>';
        feedbackEl.className = "question-feedback incorrect";
      }

      // Make the feedback visible
      feedbackEl.style.display = "block";
    }


    /* ── getRadioValue(name) ────────────────────────────────────
       Returns the value of the selected radio button for a given
       input group name, or null if nothing is selected.
    ─────────────────────────────────────────────────────────── */
    function getRadioValue(name) {
      const selected = document.querySelector('input[name="' + name + '"]:checked');
      return selected ? selected.value : null;
    }


    /* ── getCheckboxValues(name) ────────────────────────────────
       Returns an array of values for all checked checkboxes with
       a given input name.
    ─────────────────────────────────────────────────────────── */
    function getCheckboxValues(name) {
      const checked = document.querySelectorAll('input[name="' + name + '"]:checked');
      return Array.from(checked).map(function(el) { return el.value; });
    }


    /* ── resetQuiz() ────────────────────────────────────────────
       Called when the user clicks "Retake Quiz".
       Clears all inputs, hides all feedback, resets the banner,
       unlocks the form, and swaps button states back to initial.
    ─────────────────────────────────────────────────────────── */
    function resetQuiz() {

      // Clear fill-in-the-blank
      document.getElementById("q1-input").value = "";

      // Uncheck all radio buttons
      document.querySelectorAll('input[type="radio"]').forEach(function(el) {
        el.checked = false;
      });

      // Uncheck all checkboxes
      document.querySelectorAll('input[type="checkbox"]').forEach(function(el) {
        el.checked = false;
      });

      // Hide all question feedback blocks
      document.querySelectorAll(".question-feedback").forEach(function(el) {
        el.style.display = "none";
        el.className = "question-feedback"; // strip correct/incorrect class
        el.innerHTML = "";
      });

      // Hide the results banner
      const banner = document.getElementById("results-banner");
      banner.style.display = "none";
      banner.className = "";
      document.getElementById("banner-result-text").textContent = "";
      document.getElementById("banner-score-text").textContent = "";

      // Unlock the form
      document.getElementById("quiz-form").classList.remove("quiz-locked");

      // Swap buttons back
      document.getElementById("btn-submit").style.display = "inline-block";
      document.getElementById("btn-reset").style.display = "none";

      // Scroll back to the top of the quiz
      document.getElementById("quiz-form").scrollIntoView({ behavior: "smooth", block: "start" });
    }

  </script>

