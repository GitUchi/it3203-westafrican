<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Quiz — West African Traditional Foods</title>
  <link rel="stylesheet" href="css/style.css" />

  <!-- Quiz-specific styles that extend the site's existing stylesheet -->
  <style>

    /* ── Quiz form container ─────────────────────────────────────── */
    .quiz-form {
      max-width: 780px;
      margin: 0 auto;
    }

    /* ── Individual question block ───────────────────────────────── */
    .question-block {
      background-color: var(--white);
      border: 1px solid var(--cream-dark);
      border-top: 4px solid var(--brown-mid);
      border-radius: 3px;
      padding: 1.6rem 1.8rem;
      margin-bottom: 1.6rem;
      box-shadow: 0 2px 6px var(--shadow);
    }

    /* Question number badge + text row */
    .question-header {
      display: flex;
      align-items: flex-start;
      gap: 0.9rem;
      margin-bottom: 1rem;
    }

    .question-number {
      background-color: var(--brown-mid);
      color: var(--cream);
      font-family: var(--font-heading);
      font-size: 0.82rem;
      font-weight: bold;
      letter-spacing: 0.04em;
      padding: 0.25rem 0.65rem;
      border-radius: 20px;
      white-space: nowrap;
      margin-top: 0.15rem;
    }

    /* Question type label (fill-in, multiple choice, etc.) */
    .question-type-label {
      font-size: 0.78rem;
      font-style: italic;
      color: var(--text-mid);
      margin-bottom: 0.5rem;
    }

    .question-text {
      font-family: var(--font-heading);
      font-size: 1.05rem;
      color: var(--brown-dark);
      line-height: 1.4;
      margin: 0;
    }

    /* ── Answer options (radio / checkbox rows) ──────────────────── */
    .options-list {
      list-style: none;
      padding: 0;
      margin: 0.4rem 0 0;
    }

    .options-list li {
      margin-bottom: 0.55rem;
    }

    /* Clickable label wrapping each radio/checkbox + text */
    .option-label {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      padding: 0.5rem 0.75rem;
      border: 1px solid var(--cream-dark);
      border-radius: 3px;
      cursor: pointer;
      font-size: 0.97rem;
      color: var(--text-dark);
      transition: background-color 0.15s ease, border-color 0.15s ease;
    }

    .option-label:hover {
      background-color: var(--cream-dark);
      border-color: var(--tan);
    }

    /* Highlight selected option */
    .option-label input[type="radio"]:checked + span,
    .option-label input[type="checkbox"]:checked + span {
      font-weight: bold;
      color: var(--brown-dark);
    }

    .option-label:has(input:checked) {
      background-color: var(--cream-dark);
      border-color: var(--brown-mid);
    }

    /* ── Fill-in-the-blank input ─────────────────────────────────── */
    .fill-blank-input {
      width: 100%;
      max-width: 420px;
      padding: 0.55rem 0.85rem;
      font-family: var(--font-body);
      font-size: 0.97rem;
      color: var(--text-dark);
      background-color: var(--white);
      border: 1px solid var(--tan);
      border-radius: 3px;
      margin-top: 0.5rem;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .fill-blank-input:focus {
      outline: none;
      border-color: var(--brown-mid);
      box-shadow: 0 0 0 3px rgba(107, 58, 31, 0.12);
    }

    /* ── Submit & Reset buttons ──────────────────────────────────── */
    .quiz-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-top: 2rem;
    }

    .btn-submit {
      background-color: var(--brown-dark);
      color: var(--cream);
      font-family: var(--font-heading);
      font-size: 1rem;
      letter-spacing: 0.04em;
      padding: 0.7rem 2rem;
      border: none;
      border-radius: 3px;
      cursor: pointer;
      transition: background-color 0.2s ease;
    }

    .btn-submit:hover {
      background-color: var(--brown-mid);
    }

    .btn-reset {
      background-color: transparent;
      color: var(--brown-mid);
      font-family: var(--font-heading);
      font-size: 1rem;
      letter-spacing: 0.04em;
      padding: 0.7rem 2rem;
      border: 2px solid var(--brown-mid);
      border-radius: 3px;
      cursor: pointer;
      transition: background-color 0.2s ease, color 0.2s ease;
      display: none; /* Hidden until quiz is graded */
    }

    .btn-reset:hover {
      background-color: var(--brown-mid);
      color: var(--cream);
    }

    /* ── Results summary banner ──────────────────────────────────── */
    #results-banner {
      display: none; /* Hidden until quiz is submitted */
      margin-bottom: 2rem;
      padding: 1.6rem 2rem;
      border-radius: 3px;
      border-left: 6px solid;
    }

    #results-banner.pass {
      background-color: #e8f5e9;
      border-color: #388e3c;
      color: #1b5e20;
    }

    #results-banner.fail {
      background-color: #fff3e0;
      border-color: #e65100;
      color: #bf360c;
    }

    .banner-result-label {
      font-family: var(--font-heading);
      font-size: 1.5rem;
      font-weight: bold;
      margin-bottom: 0.3rem;
    }

    .banner-score {
      font-size: 1.05rem;
    }

    /* ── Per-question feedback (shown after grading) ─────────────── */
    .question-feedback {
      display: none; /* Hidden until quiz is graded */
      margin-top: 1rem;
      padding: 0.9rem 1.1rem;
      border-radius: 3px;
      font-size: 0.93rem;
      border-left: 4px solid;
    }

    .question-feedback.correct {
      background-color: #e8f5e9;
      border-color: #388e3c;
      color: #1b5e20;
    }

    .question-feedback.incorrect {
      background-color: #fce4ec;
      border-color: #c62828;
      color: #b71c1c;
    }

    .feedback-result-icon {
      font-weight: bold;
      font-size: 1rem;
      margin-bottom: 0.3rem;
    }

    .feedback-correct-answer {
      margin-top: 0.3rem;
      font-style: italic;
    }

    /* Disable all inputs after submission */
    .quiz-locked input,
    .quiz-locked .option-label {
      pointer-events: none;
      cursor: default;
    }

    .quiz-locked .option-label:hover {
      background-color: inherit;
      border-color: var(--cream-dark);
    }

  </style>
</head>
